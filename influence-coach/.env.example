# Copy this file to .env.local and fill in real values.
# Without the Anthropic key the app still runs but AI features return a friendly stub.

# Anthropic (server-side only)
INFLUENCE_COACH_ANTHROPIC_KEY=sk-ant-your-key-here

# Supabase (client-safe — anon key is RLS-gated)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Your role (used to anchor AI prompts)
NEXT_PUBLIC_MY_ROLE="Director of Ecommerce and Performance Marketing"
NEXT_PUBLIC_MY_NAME="Michael"
